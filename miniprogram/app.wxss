/* love-train · Claude Design tokens */
page {
  /* 配色 */
  --canvas: #f7f3ec;     /* 暖米白底色 */
  --card: #efe9dd;       /* 卡片 / AI 气泡 */
  --ink: #1f1f1c;        /* 主文字 */
  --ink-mute: #5d5b56;   /* 次文字 */
  --hair: #e2dccc;       /* 1rpx 浅边框 */
  --orange: #cc785c;     /* Claude 橙 · 主操作 / 强调 */
  --burgundy: #8b3a3a;   /* 深酒红 · 危险 / 警告 */

  background: #f7f3ec;
  color: #1f1f1c;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 30rpx;
  line-height: 1.5;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 黑底主操作（登录用） */
.btn-primary {
  background: #1f1f1c;
  color: #fff;
  border: none;
  border-radius: 24rpx;
  height: 104rpx;
  line-height: 104rpx;
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.btn-primary[disabled] {
  background: #9a9a9a;
  color: #fafafa;
}

/* 衬线斜体（品牌点睛） */
.serif-italic {
  font-family: "Source Serif", "Songti SC", "STSong", serif;
  font-style: italic;
  font-weight: 400;
  letter-spacing: -0.01em;
}
