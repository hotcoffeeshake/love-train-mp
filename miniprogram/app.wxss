/* 全局基础样式 */
page {
  background: #f5f5f7;
  color: #1c1c1e;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 32rpx;
  line-height: 1.5;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.btn-primary {
  background: #111;
  color: #fff;
  border: none;
  border-radius: 999rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary[disabled] {
  background: #9a9a9a;
  color: #fff;
}
