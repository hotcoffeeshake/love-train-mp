.row {
  display: flex;
  margin: 16rpx 32rpx;
}

.row-user {
  justify-content: flex-end;
}

.row-assistant {
  justify-content: flex-start;
}

.msg-col {
  max-width: 82%;
  display: flex;
  flex-direction: column;
}

.row-user .msg-col {
  align-items: flex-end;
}

.row-assistant .msg-col {
  align-items: flex-start;
}

/* 诊断中标签 */
.ai-tag {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: #cc785c;
  letter-spacing: 0.02em;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.ai-tag .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #cc785c;
}

/* 气泡 */
.bubble {
  padding: 20rpx 28rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  line-height: 1.55;
  word-break: break-word;
  white-space: pre-wrap;
}

.bubble-user {
  background: #1f1f1c;
  color: #fff;
}

.bubble-assistant {
  background: #efe9dd;
  color: #1f1f1c;
  border: 1rpx solid #e2dccc;
}

.caret {
  display: inline-block;
  width: 6rpx;
  height: 28rpx;
  background: #1f1f1c;
  margin-left: 4rpx;
  vertical-align: text-bottom;
}

.images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #d8cfc0;
  border: 1rpx solid #e2dccc;
}
