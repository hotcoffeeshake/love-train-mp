<view class="page">
  <!-- Identity -->
  <view class="identity">
    <view class="logo serif-italic">l</view>
    <view class="brand serif-italic">love-train</view>
    <view class="version">v {{version}} · 体验版</view>
  </view>

  <!-- Subscribe entry card (highlighted) -->
  <view class="card card-accent" bindtap="onOpenSubscribe">
    <view class="dot dot-glow"></view>
    <view class="card-body">
      <view class="card-title" wx:if="{{user.is_paid}}">会员中心</view>
      <view class="card-title" wx:else>开通付费版</view>
      <view class="card-meta" wx:if="{{user.is_paid}}">有效期至 {{expireText}} · 续费 ¥20/月</view>
      <view class="card-meta" wx:else>每日 30 次 · 免广告</view>
    </view>
    <view class="chevron chevron-bold">›</view>
  </view>

  <!-- Cards -->
  <view class="cards">
    <view class="card" bindtap="onAgreement" data-type="user">
      <view class="dot"></view>
      <view class="card-body">
        <view class="card-title">用户协议</view>
        <view class="card-meta">上次更新 2026.03</view>
      </view>
      <view class="chevron">›</view>
    </view>

    <view class="card" bindtap="onAgreement" data-type="privacy">
      <view class="dot"></view>
      <view class="card-body">
        <view class="card-title">隐私政策</view>
        <view class="card-meta">不收集你的聊天内容</view>
      </view>
      <view class="chevron">›</view>
    </view>

    <view class="card" bindtap="onContact">
      <view class="dot"></view>
      <view class="card-body">
        <view class="card-title">联系我们</view>
        <view class="card-meta">微信 UnheardBili</view>
      </view>
      <view class="chevron">›</view>
    </view>
  </view>

  <!-- Danger -->
  <view class="danger-zone">
    <button class="danger-btn" bindtap="onClearLocal">清空本地聊天记录</button>
    <view class="danger-hint">聊天仅存于本机，清空后不可恢复。</view>
  </view>

  <view class="footer">ESCAPE STUDIO · 2026</view>
</view>
