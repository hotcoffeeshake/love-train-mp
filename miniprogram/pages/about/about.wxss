.page {
  min-height: 100vh;
  background: #f7f3ec;
  padding: 48rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
}

/* Identity 块 */
.identity {
  text-align: center;
  padding: 48rpx 32rpx 64rpx;
}

.logo {
  display: inline-block;
  width: 128rpx;
  height: 128rpx;
  border-radius: 32rpx;
  background: #1f1f1c;
  color: #cc785c;
  line-height: 128rpx;
  font-size: 88rpx;
  margin-bottom: 32rpx;
}

.brand {
  font-size: 44rpx;
  color: #1f1f1c;
  line-height: 1.2;
  margin-bottom: 12rpx;
}

.version {
  font-size: 24rpx;
  color: #5d5b56;
  font-variant-numeric: tabular-nums;
  margin-bottom: 28rpx;
  letter-spacing: 0.04em;
}

.desc {
  font-size: 26rpx;
  color: #5d5b56;
  line-height: 1.6;
  white-space: pre-line;
  max-width: 560rpx;
  margin: 0 auto;
}

/* 卡片 */
.cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #efe9dd;
  border: 1rpx solid #e2dccc;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #cc785c;
  flex-shrink: 0;
}

.card-body {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  color: #1f1f1c;
  line-height: 1.3;
}

.card-meta {
  font-size: 22rpx;
  color: #5d5b56;
  margin-top: 6rpx;
  line-height: 1.4;
}

.chevron {
  color: #5d5b56;
  font-size: 32rpx;
  line-height: 1;
}

/* 危险区 */
.danger-zone {
  margin-top: 48rpx;
  padding: 0 16rpx;
}

.danger-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: transparent;
  color: #8b3a3a;
  border: 1rpx solid #8b3a3a;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.danger-hint {
  font-size: 22rpx;
  color: #5d5b56;
  text-align: center;
  margin-top: 20rpx;
  line-height: 1.5;
}

/* Footer */
.footer {
  margin-top: auto;
  padding-top: 64rpx;
  text-align: center;
  font-size: 22rpx;
  color: #5d5b56;
  letter-spacing: 0.08em;
}

/* Subscribe entry card — slightly bolder accent */
.card-accent {
  margin-bottom: 20rpx;
}
.card-accent .card-title {
  font-weight: 500;
}
.dot-glow {
  width: 16rpx;
  height: 16rpx;
  box-shadow: 0 0 0 6rpx rgba(204, 120, 92, 0.18);
}
.chevron-bold {
  color: #1f1f1c;
}
