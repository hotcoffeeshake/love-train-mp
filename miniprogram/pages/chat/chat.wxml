<view class="page">
  <view class="header">
    <view class="brand">
      <view class="avatar serif-italic">l</view>
      <view class="brand-text">
        <view class="name">love-train</view>
        <quota-badge remaining="{{user.remainingUses}}" limit="10" />
      </view>
    </view>
    <view class="more" bindtap="onAbout">···</view>
  </view>

  <scroll-view
    class="list"
    scroll-y
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation>
    <view wx:if="{{messages.length === 0}}" class="empty">
      <view class="empty-line">兄弟，把你那情况发我看看。</view>
      <view class="empty-sub">文字、聊天截图、对方主页都行。</view>
    </view>
    <message-bubble
      wx:for="{{messages}}"
      wx:key="id"
      id="{{item.id}}"
      role="{{item.role}}"
      content="{{item.content}}"
      loading="{{item.pending}}"
      fileIDs="{{item.fileIDs || []}}"
    />
  </scroll-view>

  <view wx:if="{{pendingFileIDs.length > 0}}" class="pending-images">
    <view wx:for="{{pendingFileIDs}}" wx:key="*this" class="pending-thumb">
      <image src="{{item}}" mode="aspectFill" class="pending-img" />
      <view class="remove" data-idx="{{index}}" bindtap="onRemoveImage">×</view>
    </view>
    <view class="pending-hint">{{pendingFileIDs.length}} 张图片待发送</view>
  </view>

  <view class="composer safe-bottom">
    <view
      class="add-btn {{uploadingImages ? 'add-btn-loading' : ''}}"
      bindtap="onPickImages">
      {{uploadingImages ? '…' : '+'}}
    </view>
    <textarea
      class="input"
      placeholder="{{quotaExhausted ? '今日 10 次已用完' : '说点什么…'}}"
      placeholder-class="input-ph"
      value="{{draft}}"
      disabled="{{quotaExhausted}}"
      auto-height
      maxlength="-1"
      cursor-spacing="20"
      show-confirm-bar="{{false}}"
      adjust-position="{{true}}"
      bindinput="onInput" />
    <view
      class="send {{(sending || (!draft.length && pendingFileIDs.length === 0) || quotaExhausted) ? 'send-disabled' : ''}}"
      bindtap="onSend">
      {{sending ? '…' : '↑'}}
    </view>
  </view>

  <view class="clear-wrap" bindtap="onClearHistory" wx:if="{{messages.length > 0}}">
    清空聊天
  </view>
</view>
