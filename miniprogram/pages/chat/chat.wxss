.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f7f3ec;
}

/* 顶栏：米白底 + 下边线 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #f7f3ec;
  border-bottom: 1rpx solid #e2dccc;
}

.brand {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #cc785c;
  color: #fff;
  text-align: center;
  line-height: 72rpx;
  font-size: 44rpx;
  flex-shrink: 0;
}

.brand-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1c;
  line-height: 1.2;
}

.more {
  padding: 0 16rpx;
  font-size: 36rpx;
  color: #5d5b56;
  letter-spacing: -4rpx;
}

/* 消息区 */
.list {
  flex: 1;
  overflow: hidden;
}

.empty {
  text-align: center;
  color: #5d5b56;
  padding: 160rpx 48rpx;
}

.empty-line {
  font-size: 30rpx;
  color: #1f1f1c;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.empty-sub {
  font-size: 24rpx;
  color: #5d5b56;
  line-height: 1.5;
}

/* 输入区 */
.composer {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #f7f3ec;
  border-top: 1rpx solid #e2dccc;
}

.input {
  flex: 1;
  min-height: 72rpx;
  max-height: 240rpx;
  padding: 18rpx 28rpx;
  background: #efe9dd;
  border: 1rpx solid #e2dccc;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.5;
  color: #1f1f1c;
  box-sizing: border-box;
}

.input-ph {
  color: #5d5b56;
  font-size: 30rpx;
}

/* 发送按钮：橙色圆形 */
.send {
  width: 72rpx;
  height: 72rpx;
  line-height: 68rpx;
  text-align: center;
  border-radius: 50%;
  background: #cc785c;
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.send-disabled {
  background: #d6d6d6;
  color: #fafafa;
}

/* + 按钮：米白圆形 */
.add-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 68rpx;
  text-align: center;
  border: 1rpx solid #e2dccc;
  border-radius: 50%;
  font-size: 36rpx;
  color: #1f1f1c;
  background: transparent;
  flex-shrink: 0;
}

.add-btn-loading {
  color: #5d5b56;
  font-size: 24rpx;
}

/* 待发送图片 */
.pending-images {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  background: #f7f3ec;
  border-top: 1rpx solid #e2dccc;
  flex-wrap: wrap;
  align-items: center;
}

.pending-thumb {
  position: relative;
  width: 112rpx;
  height: 112rpx;
}

.pending-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: #d8cfc0;
  border: 1rpx solid #e2dccc;
}

.remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 32rpx;
  text-align: center;
  background: #1f1f1c;
  color: #fff;
  border-radius: 50%;
  font-size: 22rpx;
}

.pending-hint {
  font-size: 22rpx;
  color: #5d5b56;
}

/* 清空聊天悬浮按钮 */
.clear-wrap {
  position: absolute;
  right: 32rpx;
  bottom: 200rpx;
  background: #efe9dd;
  border: 1rpx solid #e2dccc;
  color: #5d5b56;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}
