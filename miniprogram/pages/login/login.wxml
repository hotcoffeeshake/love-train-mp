<view class="page">
  <!-- Hero -->
  <view class="hero">
    <view class="mark serif-italic">l</view>
    <view class="title serif-italic">love-train</view>
    <view class="tagline">兄弟，遇到什么情况了，\n发给我看看。</view>
  </view>

  <!-- CTA -->
  <view class="cta safe-bottom">
    <button
      class="btn-login"
      disabled="{{!agreed || loading}}"
      loading="{{loading}}"
      bindtap="onLogin">
      <text class="btn-mark" wx:if="{{!loading}}">✓</text>
      <text>{{loading ? '登录中…' : '微信一键登录'}}</text>
    </button>

    <view wx:if="{{errorMsg}}" class="error">{{errorMsg}}</view>

    <view class="agree" bindtap="onToggleAgree">
      <view class="checkbox {{agreed ? 'on' : ''}}">
        <text wx:if="{{agreed}}">✓</text>
      </view>
      <view class="agree-text">
        已阅读并同意
        <text class="link" catchtap="onAbout">《用户协议》</text>
        与
        <text class="link" catchtap="onAbout">《隐私政策》</text>
      </view>
    </view>

    <view class="footer">出品 · ESCAPE STUDIO</view>
  </view>
</view>
