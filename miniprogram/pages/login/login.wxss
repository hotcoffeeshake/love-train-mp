.container {
  min-height: 100vh;
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero {
  text-align: center;
  margin-bottom: 120rpx;
}

.logo {
  font-size: 140rpx;
  color: #111;
}

.title {
  font-size: 56rpx;
  font-weight: 600;
  margin-top: 20rpx;
}

.subtitle {
  color: #888;
  margin-top: 12rpx;
  font-size: 28rpx;
}

.form {
  width: 100%;
}

.error {
  margin-top: 24rpx;
  color: #e02020;
  font-size: 26rpx;
  text-align: center;
}

.agree {
  margin-top: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #888;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  border: 2rpx solid #bbb;
  border-radius: 8rpx;
  text-align: center;
  line-height: 28rpx;
  font-size: 24rpx;
  color: #fff;
}

.checkbox.on {
  background: #111;
  border-color: #111;
}

.link {
  color: #111;
  text-decoration: underline;
}
