{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2020"],
    "types": ["miniprogram-api-typings"],
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "removeComments": true,
    "preserveConstEnums": true,
    "outDir": "./",
    "rootDir": "./"
  },
  "include": ["**/*.ts", "typings/**/*.d.ts"],
  "exclude": ["node_modules", "test"]
}
